{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc",
    "import",
    "promise",
    "react",
    "react-perf",
    "jsx-a11y"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "env": {
    "builtin": true,
    "node": true,
    "es2024": true
  },
  "ignorePatterns": [
    "convex/_generated/**",
    ".convex/**",
    "dist/**",
    "node_modules/**"
  ],
  "rules": {
    "no-underscore-dangle": ["warn", { "allow": ["_id", "_creationTime"] }],
    "react/react-in-jsx-scope": "off",
    "import/no-unassigned-import": [
      "warn",
      { "allow": ["**/*.css", "**/*.scss"] }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx"],
      "plugins": ["vitest"],
      "env": { "vitest": true },
      "rules": {
        "vitest/require-to-throw-message": "off"
      }
    }
  ]
}
